# ============================================================================
# BekiBuffet SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# Database (SQLite — path relative to project root)
DATABASE_URL=file:./db/custom.db

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (optional but recommended for production)
# When both GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set, the
# "Continue with Google" button automatically appears on the sign-in page.
#
# Setup steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create or select a project
# 3. Navigate to APIs & Services → Credentials
# 4. Click "Create Credentials" → "OAuth 2.0 Client ID"
# 5. Set Application Type to "Web application"
# 6. Add Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google  (development)
#    - https://yourdomain.com/api/auth/callback/google  (production)
# 7. Copy the Client ID and Client Secret here:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Demo account password (used by /api/seed for demo@bekibuffet.ai)
DEMO_PASSWORD=bekibuffet

# Setup token for provisioning demo accounts in production (optional)
# When set, /api/seed requires this token via the X-Setup-Token header
# SETUP_TOKEN=your-secure-setup-token

# Stripe (optional — for real payment collection)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
