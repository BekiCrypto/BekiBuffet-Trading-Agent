# ============================================================================
# BekiBuffet SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# PostgreSQL (Neon) is the single source of truth for all environments.
# ============================================================================

# Database — Neon PostgreSQL connection string
# Get this from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/bekibuffet?sslmode=require

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (set to enable Google sign-in)
# See README.md for setup guide
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Credential Encryption — REQUIRED in production
# Used to encrypt broker API keys/secrets at rest (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Stripe (for real payment processing)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=
# Create products in Stripe for each paid tier, then copy price IDs:
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
STRIPE_PRICE_INSTITUTIONAL=

# Market Data — TwelveData API (for real-time prices + historical candles)
# Free tier: 8 req/min, 800/day — https://twelvedata.com/pricing
TWELVEDATA_API_KEY=

# Email — Resend (for trade alerts + notifications)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=BekiBuffet <noreply@bekibuffet.ai>

# Cron job authentication
# Generate: openssl rand -hex 32
# Set the same value in Vercel + use in cron header: Authorization: Bearer <secret>
CRON_SECRET=

# Demo account password (used by /api/seed for demo@bekibuffet.ai)
DEMO_PASSWORD=bekibuffet

# Setup token for provisioning demo accounts in production (optional)
# SETUP_TOKEN=your-secure-setup-token

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
