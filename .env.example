# ============================================================================
# BekiBuffet SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# Crypto payments via USDT BEP-20 (Binance Smart Chain) — self-custody.
# ============================================================================

# Database — Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/bekibuffet?sslmode=require

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (set to enable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Credential Encryption — REQUIRED in production
# Used to encrypt broker API keys/secrets at rest (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# Crypto Payments — Self-Custody (USDT BEP-20)
# ============================================================================
# Your BSC wallet address where users send USDT payments.
# Funds go DIRECTLY to your wallet — no third party, no NOWPayments,
# no intermediary. Full self-custody.
#
# Any BSC-compatible wallet works:
#   - MetaMask
#   - Trust Wallet
#   - Binance Wallet
#   - Ledger/Trezor (hardware wallets)
#
# To get your address:
#   1. Create or open your wallet
#   2. Switch to BSC (Binance Smart Chain) network
#   3. Copy your address (starts with 0x, 42 characters)
#   4. Paste below
CRYPTO_RECEIVING_WALLET=0x2E303818319a6359a26AF5eBFc50De01eD06d094

# Optional: custom BSC RPC URL
# Defaults to public BSC endpoint (rate-limited)
# For production, use a paid RPC for higher reliability:
#   - QuickNode: https://www.quicknode.com
#   - Alchemy: https://www.alchemy.com
#   - Ankr: https://www.ankr.com
BSC_RPC_URL=

# ============================================================================
# Other Services
# ============================================================================

# Market Data — TwelveData API (for real-time prices + historical candles)
TWELVEDATA_API_KEY=

# Email — Resend (for trade alerts + notifications)
RESEND_API_KEY=
FROM_EMAIL=BekiBuffet <noreply@bekibuffet.ai>

# Cron job authentication
# Generate: openssl rand -hex 32
CRON_SECRET=

# Demo account password
DEMO_PASSWORD=bekibuffet

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
