# ============================================================================
# BekiBuffet SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# PostgreSQL (Neon) is the single source of truth for all environments.
# ============================================================================

# Database — Neon PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Get this from your Neon dashboard: https://console.neon.tech
#
# Example:
#   DATABASE_URL=postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/bekibuffet?sslmode=require
#
# In Vercel, set this as an environment variable in your project settings.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/bekibuffet?sslmode=require

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (optional but recommended for production)
# When both GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set, the
# "Continue with Google" button automatically appears on the sign-in page.
#
# Setup steps (see README.md for full guide):
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 4. For production, add: https://yourdomain.com/api/auth/callback/google
# 5. Copy Client ID and Secret here:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Demo account password (used by /api/seed for demo@bekibuffet.ai)
DEMO_PASSWORD=bekibuffet

# Setup token for provisioning demo accounts in production (optional)
# SETUP_TOKEN=your-secure-setup-token

# Stripe (optional — for real payment collection)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
