# ============================================================================
# BekiBuffet SaaS — Environment Variables
# Copy this file to .env and fill in your values.
# Crypto payments via USDT BEP-20 (Binance Smart Chain).
# ============================================================================

# Database — Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/bekibuffet?sslmode=require

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (set to enable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Credential Encryption — REQUIRED in production
# Used to encrypt broker API keys/secrets at rest (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================================
# Crypto Payments (USDT BEP-20) — Choose ONE mode:
# ============================================================================

# Mode 1: NOWPayments Gateway (recommended)
#   Handles wallet generation, payment tracking, and webhooks automatically.
#   Sign up at https://nowpayments.io → create API key + IPN secret
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_API_URL=https://api.nowpayments.io
NOWPAYMENTS_IPN_SECRET=

# Mode 2: Direct Blockchain (more decentralized)
#   Set your BSC wallet address. Users send USDT BEP-20 to this address.
#   The system monitors BSC for incoming transfers and verifies on-chain.
#   Your wallet: any BSC-compatible wallet (MetaMask, Trust Wallet, etc.)
CRYPTO_RECEIVING_WALLET=
#   Optional: custom BSC RPC URL (defaults to public BSC endpoint)
BSC_RPC_URL=

# ============================================================================
# Other Services
# ============================================================================

# Market Data — TwelveData API (for real-time prices + historical candles)
TWELVEDATA_API_KEY=

# Email — Resend (for trade alerts + notifications)
RESEND_API_KEY=
FROM_EMAIL=BekiBuffet <noreply@bekibuffet.ai>

# Cron job authentication
# Generate: openssl rand -hex 32
CRON_SECRET=

# Demo account password
DEMO_PASSWORD=bekibuffet

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
