# Database
DATABASE_URL=file:./db/custom.db

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth (optional — leave blank to use demo credentials only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to 1 to show Google OAuth button on sign-in page
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=

# Stripe (optional — for real payment collection)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
