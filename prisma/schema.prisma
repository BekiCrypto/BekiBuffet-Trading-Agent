// ============================================================================
// BekiBuffet SaaS — Prisma Schema
// Multi-tenant autonomous trading agent system with subscriptions,
// broker connections, backtests, edge profiles, and AI agent state.
//
// Database: PostgreSQL (Neon) — single source of truth for all environments.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Auth (NextAuth.js core models)
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String? // for demo credentials login
  role          String    @default("USER") // USER | ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  brokerAccounts BrokerAccount[]
  backtests      Backtest[]
  edgeProfiles   EdgeProfile[]
  agentStates    AgentState[]
  trades         Trade[]
  aiDecisions    AIDecision[]
  activityLog    ActivityLog[]
  payments       CryptoPayment[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String // google | credentials
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Subscription System
// ----------------------------------------------------------------------------

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  tier                 String    @default("FREE") // FREE | PRO | ELITE | INSTITUTIONAL
  status               String    @default("ACTIVE") // ACTIVE | PAST_DUE | CANCELED | TRIALING
  // Crypto payment fields (USDT BEP-20)
  walletAddress        String?   // user's deposit address for payments
  paymentId            String?   // NOWPayments payment ID
  lastPaymentTxHash    String?   // blockchain tx hash of last payment
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  seats                Int       @default(1) // number of broker accounts allowed
  maxCapitalUsd        Int       @default(25000) // max AUM managed
  riskLimitPct         Float     @default(1.0) // max risk per trade
  backtestCredits      Int       @default(50) // monthly backtest runs
  aiAgentEnabled       Boolean   @default(false)
  edgeDiscoveryEnabled Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments             CryptoPayment[]
}

// ----------------------------------------------------------------------------
// Crypto Payments (USDT BEP-20)
// ----------------------------------------------------------------------------

model CryptoPayment {
  id              String   @id @default(cuid())
  userId          String
  subscriptionId  String?
  tier            String   // PRO | ELITE | INSTITUTIONAL
  amount          Float    // USD amount
  amountUsdt      Float    // USDT amount (6 decimals)
  currency        String   @default("USDT")
  network         String   @default("BSC") // BEP-20
  status          String   @default("PENDING") // PENDING | CONFIRMED | FAILED | EXPIRED
  txHash          String?  // blockchain transaction hash
  fromAddress     String?  // sender wallet address
  toAddress       String?  // receiving wallet address
  paymentId       String?  // NOWPayments payment ID (if using gateway)
  confirmations   Int      @default(0)
  blockNumber     BigInt?
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
  expiresAt       DateTime?

  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([txHash])
}


model BrokerAccount {
  id           String    @id @default(cuid())
  userId       String
  brokerType   String // MT5 | OANDA | BINANCE | INTERACTIVE_BROKERS | DEMO
  accountName  String
  accountId    String
  apiKey       String? // encrypted at app layer
  apiSecret    String? // encrypted at app layer
  server       String? // for MT5
  leverage     Float     @default(100)
  baseCurrency String    @default("USD")
  balance      Float     @default(0)
  equity       Float     @default(0)
  currency     String    @default("USD")
  isConnected  Boolean   @default(false)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades       Trade[]

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Backtesting
// ----------------------------------------------------------------------------

model Backtest {
  id             String    @id @default(cuid())
  userId         String
  name           String
  asset          String // XAUUSD | EURUSD | ...
  strategy       String // BEKIBUFFET_V1 | ICHIMOKU_CLOUD | MOMENTUM_BREAKOUT | ...
  timeframe      String // M5 | M15 | H1 | H4
  startDate      DateTime
  endDate        DateTime
  initialCapital Float     @default(10000)
  parameters     String    @db.Text // JSON string
  status         String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  // Results
  finalEquity    Float?
  totalReturn    Float?
  maxDrawdown    Float?
  sharpeRatio    Float?
  winRate        Float?
  profitFactor   Float?
  totalTrades    Int?
  avgWinUsd      Float?
  avgLossUsd     Float?
  equityCurve    String?   @db.Text // JSON array of {t, equity}
  tradesJson     String?   @db.Text // JSON array of trades
  duration       Int? // ms
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ----------------------------------------------------------------------------
// Edge Discovery — autonomous parameter search
// ----------------------------------------------------------------------------

model EdgeProfile {
  id               String    @id @default(cuid())
  userId           String
  name             String
  asset            String
  description      String    @db.Text
  // Best parameters found
  parameters       String    @db.Text // JSON
  // Performance metrics from walk-forward
  winRate          Float
  profitFactor     Float
  sharpeRatio      Float
  maxDrawdown      Float
  totalTrades      Int
  avgRoiPerTrade   Float
  // Validation
  walkForwardScore Float // 0-100
  inSampleScore    Float
  outOfSampleScore Float
  // Status
  status           String    @default("DISCOVERED") // DISCOVERED | VALIDATED | DEPLOYED | RETIRED
  deployedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, walkForwardScore])
  @@index([userId, status])
}

// ----------------------------------------------------------------------------
// Per-user Agent State (persisted BekiBuffet state)
// ----------------------------------------------------------------------------

model AgentState {
  id                String    @id @default(cuid())
  userId            String
  brokerAccountId   String    @default("PAPER") // "PAPER" = paper trading, else broker account ID
  mode              String    @default("PAUSED") // PAUSED | RUNNING | HALTED
  equity            Float     @default(10000)
  balance           Float     @default(10000)
  floatingPnl       Float     @default(0)
  dayStartEquity    Float     @default(10000)
  consecutiveLosses Int       @default(0)
  ticksProcessed    Int       @default(0)
  decisionsTaken    Int       @default(0)
  decisionsRejected Int       @default(0)
  decisionsWaiting  Int       @default(0)
  campaignsActive   Int       @default(0)
  selfLearningJson  String?   @db.Text // self-learning state serialized
  activeAssets      String?   @db.Text // JSON array of asset symbols
  lastTickAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brokerAccountId])
}

// ----------------------------------------------------------------------------
// Trades (live + paper)
// ----------------------------------------------------------------------------

model Trade {
  id                 String         @id @default(cuid())
  userId             String
  brokerAccountId    String?
  asset              String
  direction          String // LONG | SHORT
  size               Float
  entryPrice         Float
  exitPrice          Float?
  stopLoss           Float
  takeProfit         Float
  status             String         @default("OPEN") // OPEN | CLOSED
  pnl                Float?
  pnlPct             Float?
  mfe                Float?
  mae                Float?
  entryScore         Int
  marketRegime       String?
  ichimokuState      String?
  priceActionPattern String?
  exitReason         String?
  openTime           DateTime       @default(now())
  closeTime          DateTime?
  duration           Int? // ms
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  brokerAccount      BrokerAccount? @relation(fields: [brokerAccountId], references: [id])

  @@index([userId, status])
  @@index([userId, closeTime])
  @@index([brokerAccountId])
}

// ----------------------------------------------------------------------------
// AI Agent Decisions — LLM-powered meta-decisions
// ----------------------------------------------------------------------------

model AIDecision {
  id         String   @id @default(cuid())
  userId     String
  asset      String
  decision   String // OPEN | SCALE | CLOSE | REJECT | REBALANCE | HEDGE
  reasoning  String   @db.Text // LLM-generated reasoning
  confidence Float // 0-1
  factors    String?  @db.Text // JSON of contributing factors
  actioned   Boolean  @default(false) // whether the trade desk executed it
  pnl        Float? // realized pnl if actioned and closed
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ----------------------------------------------------------------------------
// Activity Log (audit trail)
// ----------------------------------------------------------------------------

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String // AUTH | SUBSCRIPTION | BROKER | TRADE | BACKTEST | EDGE | AGENT
  action    String
  detail    String?  @db.Text
  meta      String?  @db.Text // JSON
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
